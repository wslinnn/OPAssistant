{
    "name" : "OPAssistant",
    "appid" : "__UNI__YOUR_APPID__",
    "description" : "OpenWrt assistant",
    "versionName" : "1.0.12",
    "versionCode" : 112,
    "transformPx" : false,
    "app-plus" : {
        "usingComponents" : true,
        "nvueStyleCompiler" : "uni-app",
        "compilerVersion" : 5.0700000000000003,
        "statusbar" : {
            "immersed" : "supportedDevice",
            "style" : "dark",
            "background" : "#F8F8F8"
        },
        "safearea" : {
            "background" : "#FFFFFF",
            "bottom" : {
                "offset" : "auto"
            }
        },
        "splashscreen" : {
            "alwaysShowBeforeRender" : false,
            "waiting" : false,
            "autoclose" : true,
            "delay" : 0
        },
        "ssl" : {
            "untrustedca" : "accept",
            "verify" : false
        },
        "modules" : {},
        "distribute" : {
            "android" : {
                "permissions" : [
                    "<uses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/>",
                    "<uses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/>"
                ],
                "minSdkVersion" : 19
            },
            "ios" : {
                "dSYMs" : false,
                "idfa" : false
            },
            "sdkConfigs" : {}
        }
    },
    "quickapp" : {},
    "mp-weixin" : {},
    "mp-alipay" : {
        "usingComponents" : true
    },
    "mp-baidu" : {
        "usingComponents" : true
    },
    "mp-toutiao" : {
        "usingComponents" : true
    },
    "h5" : {
        "devServer" : {
            "port" : 8080,
            "disableHostCheck" : true,
            "proxy" : {
                "/ubus" : {
                    "target" : "http://192.168.1.1",
                    "changeOrigin" : true,
                    "secure" : false
                },
                "/cgi-bin/luci" : {
                    "target" : "http://192.168.1.1",
                    "changeOrigin" : true,
                    "secure" : false
                }
            }
        }
    },
    "uniStatistics" : {
        "enable" : false
    },
    "vueVersion" : "2",
    "locale" : "auto",
    "fallbackLocale" : "en",
    "darkmode" : false
}
